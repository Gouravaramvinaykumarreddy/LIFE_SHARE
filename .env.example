# LifeShare Environment Variables (Example)

# Database Config (PostgreSQL)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifeshare

# Database Config (Local SQLite Fallback)
USE_SQLITE=true
SQLITE_PATH=./lifeshare.db

# Client Config (Vite)
# If running locally without Docker:
VITE_API_URL=http://localhost:5000/api
# If running with Docker, it proxies automatically via nginx.
